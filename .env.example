# ============================================
# EsfotGo — Variables de entorno
# ============================================
# Copia este archivo como .env y ajusta los valores

# API del backend Express + MongoDB
# Producción → https://esfotgo-componente-backend.vercel.app/api
# Desarrollo local → http://localhost:3000/api
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000/api

# Modo desarrollo (usa mock data en algunos módulos)
EXPO_PUBLIC_DEV_MODE=true

# Google Maps (requerido para el mapa)
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here
